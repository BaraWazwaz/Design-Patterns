# Doxyfile 1.16.1 (FIXED)

#---------------------------------------------------------------------------
# Project Information
#---------------------------------------------------------------------------

PROJECT_NAME           = "Design Patterns"
PROJECT_NUMBER         =
PROJECT_BRIEF          = "C++ Design Patterns Implementation"

OUTPUT_DIRECTORY       = docs/output
CREATE_SUBDIRS         = YES
OUTPUT_LANGUAGE        = English

#---------------------------------------------------------------------------
# Input Configuration
#---------------------------------------------------------------------------

# Only parse headers (public API)
INPUT                  = include

RECURSIVE              = YES

# 🔥 STRICT: Only headers
FILE_PATTERNS          = *.hpp

# Explicitly exclude everything else (defensive safety)
EXCLUDE_PATTERNS       = *.cpp *.c *.cc *.tpp

# Exclude irrelevant directories
EXCLUDE                = build bin docs/output .git .github

#---------------------------------------------------------------------------
# Build Configuration
#---------------------------------------------------------------------------

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES

FULL_PATH_NAMES        = YES
SHOW_INCLUDE_FILES     = YES

TAB_SIZE               = 4

# 🔥 REQUIRED for modern C++ (concepts/templates)
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO

CLANG_ASSISTED_PARSING = YES
CLANG_OPTIONS          = -std=c++20 -Iinclude

#---------------------------------------------------------------------------
# Output Generation
#---------------------------------------------------------------------------

GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_FILE_EXTENSION    = .html
GENERATE_TREEVIEW      = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO

#---------------------------------------------------------------------------
# Visualizations (Graphviz/Dot)
#---------------------------------------------------------------------------

HAVE_DOT               = YES

UML_LOOK               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES

# Better performance in CI
DOT_NUM_THREADS        = 0
DOT_IMAGE_FORMAT       = svg

#---------------------------------------------------------------------------
# Warnings & Messaging
#---------------------------------------------------------------------------

QUIET                  = YES
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_FORMAT            = "$file:$line: $text"

# Optional strict mode (enable later)
WARN_AS_ERROR          = NO

#---------------------------------------------------------------------------
# Source Browsing
#---------------------------------------------------------------------------

SOURCE_BROWSER         = NO
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES

#---------------------------------------------------------------------------
# Lists & Traceability
#---------------------------------------------------------------------------

GENERATE_TODOLIST      = YES
GENERATE_TESTLIST      = YES
GENERATE_BUGLIST       = YES
GENERATE_DEPRECATEDLIST= YES

#---------------------------------------------------------------------------
# Misc (recommended)
#---------------------------------------------------------------------------

USE_MDFILE_AS_MAINPAGE = README.md